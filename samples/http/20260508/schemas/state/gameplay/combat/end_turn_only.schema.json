{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "游戏内界面 / 战斗只能结束回合",
  "properties": {
    "data": {
      "additionalProperties": true,
      "properties": {
        "available_actions": {
          "contains": {
            "const": "end_turn"
          },
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "combat": {
          "type": "object"
        },
        "screen": {
          "const": "COMBAT"
        }
      },
      "required": [
        "screen",
        "available_actions",
        "combat"
      ],
      "type": "object"
    },
    "ok": {
      "const": true
    },
    "request_id": {
      "type": "string"
    }
  },
  "required": [
    "ok",
    "request_id",
    "data"
  ],
  "title": "state/gameplay/combat/end_turn_only",
  "type": "object"
}
