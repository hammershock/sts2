{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "地图路线选择",
  "properties": {
    "data": {
      "additionalProperties": true,
      "properties": {
        "available_actions": {
          "contains": {
            "const": "choose_map_node"
          },
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "map": {
          "type": "object"
        },
        "screen": {
          "const": "MAP"
        }
      },
      "required": [
        "screen",
        "available_actions",
        "map"
      ],
      "type": "object"
    },
    "ok": {
      "const": true
    },
    "request_id": {
      "type": "string"
    }
  },
  "required": [
    "ok",
    "request_id",
    "data"
  ],
  "title": "state/map/route_selection",
  "type": "object"
}
