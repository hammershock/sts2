{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "游戏菜单 / 结算",
  "properties": {
    "data": {
      "additionalProperties": true,
      "properties": {
        "available_actions": {
          "contains": {
            "const": "return_to_main_menu"
          },
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "game_over": {
          "type": "object"
        },
        "screen": {
          "const": "GAME_OVER"
        }
      },
      "required": [
        "screen",
        "available_actions",
        "game_over"
      ],
      "type": "object"
    },
    "ok": {
      "const": true
    },
    "request_id": {
      "type": "string"
    }
  },
  "required": [
    "ok",
    "request_id",
    "data"
  ],
  "title": "state/game_menu/game_over",
  "type": "object"
}
