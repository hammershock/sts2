{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "description": "卡组移除选择",
  "properties": {
    "data": {
      "additionalProperties": true,
      "properties": {
        "available_actions": {
          "contains": {
            "const": "select_deck_card"
          },
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "screen": {
          "const": "CARD_SELECTION"
        },
        "selection": {
          "properties": {
            "kind": {
              "const": "deck_card_select"
            },
            "prompt": {
              "pattern": "移除",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "prompt"
          ],
          "type": "object"
        }
      },
      "required": [
        "screen",
        "available_actions",
        "selection"
      ],
      "type": "object"
    },
    "ok": {
      "const": true
    },
    "request_id": {
      "type": "string"
    }
  },
  "required": [
    "ok",
    "request_id",
    "data"
  ],
  "title": "state/card_selection/deck_remove",
  "type": "object"
}
